# ===========================================================================
# Environment template — copy to `.env` and adjust. The real `.env` is
# git-ignored so secrets never land in version control (secrets management).
#   cp .env.example .env
# ===========================================================================

# --- Application ---------------------------------------------------------
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Feature flag (Assignment 1 strategy): toggle the modern dashboard UI.
NEW_UI_ENABLED=false

# --- Grafana admin credentials -------------------------------------------
# Change these before any non-local use. Defaults exist only for local demos.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
